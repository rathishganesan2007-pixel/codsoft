import string
import secrets
import os

def clear_screen():
    """Clears the terminal screen for a professional UI experience."""
    os.system('cls' if os.name == 'nt' else 'clear')

def generate_password(length, use_upper, use_digits, use_special):
    """
    Generates a cryptographically secure random password based on custom criteria.
    """
    # Base character set always includes lowercase letters
    character_pool = string.ascii_lowercase
    
    # Expand the pool based on user complexity parameters
    if use_upper:
        character_pool += string.ascii_uppercase
    if use_digits:
        character_pool += string.digits
    if use_special:
        character_pool += string.punctuation

    # Guard clause: Ensure the pool is not empty
    if not character_pool:
        return "Error: You must select at least one character type."

    # Generate a cryptographically secure password
    password = ''.join(secrets.choice(character_pool) for _ in range(length))
    return password

def password_generator_app():
    clear_screen()
    print("========================================")
    print("        SECURE PASSWORD GENERATOR       ")
    print("========================================")

    while True:
        # 1. Prompt and validate password length
        try:
            length = int(input("\nEnter the desired password length (min 4 recommended): "))
            if length <= 0:
                print("❌ Invalid Parameter: Length must be a positive integer.")
                continue
        except ValueError:
            print("❌ Invalid Input: Please enter a valid numerical integer.")
            continue

        # 2. Collect complexity configuration parameters using explicitly "yes/no"
        print("\nConfigure Complexity Matrix Parameters:")
        include_upper = input("Include uppercase letters? (yes/no): ").strip().lower() == 'yes'
        include_digits = input("Include numeric digits? (yes/no): ").strip().lower() == 'yes'
        include_special = input("Include special symbols/punctuation? (yes/no): ").strip().lower() == 'yes'

        # 3. Generate the password string array map
        password = generate_password(length, include_upper, include_digits, include_special)

        # 4. Display the compiled manifest result safely
        print("\n----------------------------------------")
        print(f"Generated Secure Password: {password}")
        print("----------------------------------------")

        # 5. Continuous execution loop evaluation
        repeat = input("\nWould you like to generate another password? (yes/no): ").strip().lower()
        if repeat not in ['yes', 'y']:
            print("\nThank you for using the Secure Password Generator. Goodbye!")
            break
            
        clear_screen()
        print("========================================")
        print("        SECURE PASSWORD GENERATOR       ")
        print("========================================")

if __name__ == "__main__":
    password_generator_app()
